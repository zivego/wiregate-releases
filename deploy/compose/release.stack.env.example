# Canonical release configuration.
# Copy to: deploy/compose/release.stack.env

# ---------- Release metadata ----------
WIREGATE_VERSION=v1.0.0
WIREGATE_PREVIOUS_VERSION=v0.9.9
WIREGATE_REGISTRY=ghcr.io/zivego
WIREGATE_BACKEND_REPO=wiregate-backend
WIREGATE_FRONTEND_REPO=wiregate-frontend
WIREGATE_RELEASE_PROJECT_NAME=wiregate-release

# Pull behavior (set true for local image rehearsal without registry pulls).
WIREGATE_SKIP_PULL=false

# ---------- Runtime ports ----------
WIREGATE_BIND_ADDRESS=0.0.0.0
WIREGATE_BACKEND_PORT=8080
WIREGATE_FRONTEND_PORT=5173
WIREGATE_FRONTEND_SCHEME=https
# By default release-init generates self-signed TLS cert/key and wires these paths.
WIREGATE_TLS_CERT_FILE=deploy/compose/.secrets/tls/tls.crt
WIREGATE_TLS_KEY_FILE=deploy/compose/.secrets/tls/tls.key

# ---------- Bootstrap admin ----------
# Used only on first DB initialization.
WIREGATE_BOOTSTRAP_ADMIN_EMAIL=admin@wiregate.local
# Preferred source for bootstrap admin password (generated by release init).
WIREGATE_BOOTSTRAP_ADMIN_PASSWORD_FILE=deploy/compose/.secrets/bootstrap_admin_password
# Optional override. If set, this value has priority over *_PASSWORD_FILE.
# WIREGATE_BOOTSTRAP_ADMIN_PASSWORD=

# ---------- Verify user (used by release verify/gate scripts) ----------
# Recommended: dedicated admin account for automation checks.
WIREGATE_VERIFY_USER_EMAIL=codex.api@wiregate.local
WIREGATE_VERIFY_USER_PASSWORD_FILE=deploy/compose/.secrets/codex_api_password
# Optional override. If set, this value has priority over *_PASSWORD_FILE.
# WIREGATE_VERIFY_USER_PASSWORD=

# ---------- WireGate runtime settings ----------
WIREGATE_COOKIE_INSECURE=false
WIREGATE_DB_DRIVER=sqlite
WIREGATE_SQLITE_PATH=/var/lib/wiregate/wiregate.db
# Optional Phase 3+ external Postgres primary:
# WIREGATE_DB_DRIVER=postgres
# WIREGATE_POSTGRES_DSN=postgres://wiregate:replace-me@db.example.com:5432/wiregate?sslmode=require
# WIREGATE_DATABASE_URL=postgres://wiregate:replace-me@db.example.com:5432/wiregate?sslmode=require
WIREGATE_SESSION_IDLE_TIMEOUT_MINUTES=30
WIREGATE_API_MAX_BODY_BYTES=1048576
WIREGATE_API_MAX_JSON_BYTES=65536
WIREGATE_WG_SERVER_ENDPOINT=vpn.example.com:55182
WIREGATE_WG_SERVER_PUBLIC_KEY=replace-with-server-public-key
WIREGATE_WG_CLIENT_CIDR=10.77.0.0/24

# ---------- Optional OIDC SSO (Phase 2+) ----------
# Leave empty to keep local-password only login.
# WIREGATE_OIDC_DISPLAY_NAME=Single Sign-On
# WIREGATE_OIDC_ISSUER_URL=https://idp.example.com/realms/wiregate
# WIREGATE_OIDC_CLIENT_ID=wiregate
# WIREGATE_OIDC_CLIENT_SECRET_FILE=/etc/wiregate/oidc_client_secret
# WIREGATE_OIDC_REDIRECT_URL=https://vpn.example.com/api/v1/auth/oidc/callback
# WIREGATE_OIDC_SCOPES=openid,profile,email,groups
# WIREGATE_OIDC_ADMIN_GROUPS=wiregate-admin,admin
# WIREGATE_OIDC_OPERATOR_GROUPS=wiregate-operator,operator
# WIREGATE_OIDC_READONLY_GROUPS=wiregate-readonly,readonly
# Optional admin MFA/assurance requirements from OIDC claims.
# WIREGATE_OIDC_REQUIRED_ADMIN_AMR=mfa
# WIREGATE_OIDC_REQUIRED_ADMIN_ACR=urn:mace:incommon:iap:silver
# Auto-create local user on first successful OIDC login.
# WIREGATE_OIDC_AUTO_CREATE_USERS=true

# ---------- Backup settings ----------
# Current release backup/restore automation is SQLite-volume based.
# When WIREGATE_DB_DRIVER=postgres, use native PostgreSQL backup tooling instead.
WIREGATE_BACKUP_DIR=.wiregate-backups
WIREGATE_BACKUP_PASSPHRASE_FILE=/etc/wiregate/backup.pass
