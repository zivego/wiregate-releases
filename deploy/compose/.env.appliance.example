# WireGate Appliance — environment configuration.
# Copy this file to .env and set the admin password. Everything else has defaults.

# --- Required -----------------------------------------------------------------

# Admin credentials (used only on first DB initialization).
WIREGATE_BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
WIREGATE_BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-password

# --- Optional -----------------------------------------------------------------

# TLS: mount certificate files to enable built-in HTTPS.
# If omitted, the frontend serves HTTP on port 80 (put Caddy/Traefik in front).
# WIREGATE_TLS_CERT_FILE=./certs/tls.crt
# WIREGATE_TLS_KEY_FILE=./certs/tls.key

# WireGuard endpoint for agents. Auto-detected from public IP if empty.
# Override with your DNS name or static IP for production.
# WIREGATE_WG_SERVER_ENDPOINT=vpn.yourcompany.com:51820

# Frontend HTTP port (default: 80). HTTPS port (default: 443).
# WIREGATE_FRONTEND_PORT=80
# WIREGATE_FRONTEND_TLS_PORT=443

# WireGuard listen port (default: 51820).
# WIREGATE_WG_LISTEN_PORT=51820

# VPN subnet for agents (default: 10.77.0.0/24 = 254 addresses).
# WIREGATE_WG_CLIENT_CIDR=10.77.0.0/24

# WireGuard server address within the VPN subnet (default: 10.77.0.254/24).
# WIREGATE_WG_SERVER_ADDRESS=10.77.0.254/24

# Database driver: "sqlite" (default) or "postgres".
# WIREGATE_DB_DRIVER=sqlite

# PostgreSQL DSN (only when DB_DRIVER=postgres).
# WIREGATE_POSTGRES_DSN=postgres://wiregate:pass@db:5432/wiregate?sslmode=disable

# Cookie security. Default: true (insecure) for HTTP mode.
# Set to "false" when using HTTPS (direct TLS or behind a TLS proxy).
# WIREGATE_COOKIE_INSECURE=true
