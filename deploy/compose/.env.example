# WireGate published-release installer.
# Copy to repo root as `.env` before `docker compose up -d`.

# Published image tag to install.
WIREGATE_VERSION=1.0.4

# Required bootstrap admin credentials.
WIREGATE_BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
WIREGATE_BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional frontend ports.
# You can use either a plain port (`80`) or a host bind (`127.0.0.1:5656`).
# For reverse proxies such as Caddy/Traefik on the same host, prefer localhost-only binds.
# WIREGATE_FRONTEND_PORT=80
# WIREGATE_FRONTEND_TLS_PORT=443
# WIREGATE_FRONTEND_PORT=127.0.0.1:5656
# WIREGATE_FRONTEND_TLS_PORT=127.0.0.1:56443

# Optional built-in TLS. Leave unset for HTTP or put Caddy/Traefik in front.
# WIREGATE_TLS_CERT_FILE=./certs/tls.crt
# WIREGATE_TLS_KEY_FILE=./certs/tls.key

# Optional WireGuard endpoint override. If empty, the backend auto-detects it.
# WIREGATE_WG_SERVER_ENDPOINT=vpn.example.com:55182

# Optional SQLite/Postgres settings.
# WIREGATE_DB_DRIVER=sqlite
# WIREGATE_POSTGRES_DSN=postgres://wiregate:pass@db:5432/wiregate?sslmode=disable

# Cookie mode:
# - true  -> HTTP / reverse-proxy-terminated installs
# - false -> direct HTTPS on the frontend container
# WIREGATE_COOKIE_INSECURE=true
